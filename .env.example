# Database (Supabase)
# DATABASE_URL  → POSTGRES_PRISMA_URL from Supabase dashboard (pooler, port 6543, pgbouncer=true)
# DIRECT_URL    → POSTGRES_URL_NON_POOLING from Supabase dashboard (direct, port 5432, for migrations)
DATABASE_URL="postgres://postgres.xxxx:password@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgres://postgres.xxxx:password@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth
JWT_SECRET="at-least-32-character-secret-key-here"
JWT_EXPIRES_IN="7d"

# CORS — comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:5173"
# In production add your Vercel domain:
# ALLOWED_ORIGINS="https://anacastellano.vercel.app,https://anacastellano.com"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="Ana Castellano Florista <hola@anacastellano.com>"
ADMIN_EMAIL="hola@anacastellano.com"

# Google Calendar (optional)
# GOOGLE_CLIENT_EMAIL="service-account@project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GOOGLE_CALENDAR_ID="primary"

# Cloudinary — required for image uploads in production (Vercel)
CLOUDINARY_CLOUD_NAME="anacastellano"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
