# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ──────────────────────────────────────────────
# Database (Prisma)
# ──────────────────────────────────────────────
# Connection string for your PostgreSQL database.
# On Vercel use the "POSTGRES_PRISMA_URL" variable name (pooled).
POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Direct connection string (non-pooled) - required for migrations
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname?sslmode=require

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
# Minimum 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-chars
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Do NOT use "*" in production.
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# ──────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────
# Leave empty in production on Vercel — the app falls back to relative /api
# Set to your Express server URL when running frontend and backend separately.
VITE_API_URL=

# ──────────────────────────────────────────────
# Email / SMTP
# ──────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Ana Castellano <noreply@example.com>"
ADMIN_EMAIL=admin@example.com

# ──────────────────────────────────────────────
# Cloudinary (image uploads)
# ──────────────────────────────────────────────
# Full URL format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://000000000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxx@your-cloud-name

# ──────────────────────────────────────────────
# Google Calendar integration (optional)
# All three must be set to enable the calendar feature.
# ──────────────────────────────────────────────
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Replace literal \n with actual newlines when pasting the private key.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
